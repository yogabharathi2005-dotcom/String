import java.util.*;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        String s = sc.nextLine();
        String arr[] = s.split(" ");
        int len = 0;
        String res = "";
        for (int i = 0; i<arr.length;i++) 
        {
         if (arr[i].length()>len) 
         {
            len = arr[i].length();
            res = arr[i];
            }
        }
       System.out.println(res);
    }
}
